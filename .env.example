ANTHROPIC_API_KEY=
MANIFOLD_API_KEY=
POLYMARKET_ENABLED=false
POLYMARKET_MODE=paper
POLYMARKET_MIN_VOLUME=1000
POLYMARKET_API_BASE=https://gamma-api.polymarket.com
POLYMARKET_CLOB_BASE=https://clob.polymarket.com
DASHBOARD_USERNAME=admin     # Phase 2
DASHBOARD_PASSWORD=          # Phase 2

# Budget (all in USD/mana units depending on platform)
BUDGET_DAILY_LIMIT=0         # 0 = calibration mode, no real bets
BUDGET_TOTAL_LIMIT=50
KELLY_FRACTION=0.25
MIN_EDGE_THRESHOLD=0.05      # Only bet when edge > 5%

# Telegram notifications (optional — leave blank to disable)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Pipeline
POLL_INTERVAL_SECONDS=1800      # 30 minutes
MAX_MARKETS_PER_CYCLE=20
LOG_LEVEL=INFO

# Prompt version (v1_baseline or v2_market_aware)
ACTIVE_PROMPT_VERSION=v2_market_aware

# Category filtering — skip markets outside proven categories
CATEGORY_FILTER_ENABLED=true

# Daily API cost cap (USD) — halts Claude calls when exceeded
DAILY_API_BUDGET=3.0

# Nightly calibration report via Telegram
NIGHTLY_REPORT_ENABLED=true
